  add{Name="odg_remove_item",        ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_move_up",            ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_move_down",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
