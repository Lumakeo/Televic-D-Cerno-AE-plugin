PluginInfo = {
  Name        = "Confero~Agenda Manager",
  Version     = "2.2.7",
  Id          = "Confero.AgendaManager.v2",
  Description = "Gestione ordine del giorno, votazioni, sedili e audio – Televic Confero (Plixus/G4)",
  Author      = "Matteo Fioretto – Prase, a Midwich company"
}

function GetColor(props) return {40, 40, 40} end
function GetPrettyName(props) return "Confero Agenda v" .. PluginInfo.Version end

local C = {
  TV={166,207,57}, Dark={30,30,30}, Gray={80,80,80}, LtGy={153,153,153},
  Wht={255,255,255}, Grn={0,180,0}, Red={200,0,0}, Orn={220,140,0},
  Blu={0,120,200}, Hdr={45,55,70},
}

function GetProperties()
  return {
    { Name="System Type",    Type="enum",    Choices={"Plixus","G4"}, Value="Plixus" },
    { Name="Server IP",      Type="string",  Value="192.168.1.1" },
    { Name="Use HTTPS",      Type="boolean", Value=true },
    { Name="Bearer Token",   Type="string",  Value="" },
    { Name="Data File Path", Type="string",  Value="media/Televic Meeting/agendas.json" },
    { Name="Seats",          Type="integer", Min=1, Max=300, Value=25 },
    { Name="LicenseKey",     Type="string",  Value="" },
  }
end

function GetPages(props)
  return {
    { name="Ordine del Giorno / Agenda" },
    { name="Riunione / Meeting" },
    { name="Votazione / Voting" },
    { name="Risultati / Results" },
    { name="Sistema / System" },
    { name="Wireless" },
    { name="Info" },
  }
end

function GetControls(props)
  local ctrls = {}
  local function add(t) table.insert(ctrls, t) end

  -- Status / System
  add{Name="Status",           ControlType="Indicator",IndicatorType="Status",PinStyle="Output",UserPin=true,Count=1}
  add{Name="conn_status_led",  ControlType="Indicator",IndicatorType="Led",PinStyle="Output",UserPin=true,Count=1}
  add{Name="conn_status_text", ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="ConnectServer",    ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}
  add{Name="ConnectStatus",    ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="debug_log",        ControlType="Text",PinStyle="Output",UserPin=true,Count=1}

  -- Tab 1: Ordine del Giorno
  add{Name="odg_meeting_title",      ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_meeting_date",       ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_new_agenda",         ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_save_agenda",        ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_load_agenda",        ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  for i=1,4 do add{Name=string.format("odg_date_select_%d",i),ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,4 do add{Name=string.format("odg_date_label_%d",i), ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  add{Name="odg_page_prev",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_page_next",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_page_indicator",     ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_add_item",           ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_remove_item",        ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_move_up",            ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_move_down",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  for i=1,5 do add{Name=string.format("odg_item_title_%d",i),   ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,5 do add{Name=string.format("odg_item_select_%d",i),  ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,5 do add{Name=string.format("odg_item_has_vote_%d",i),ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1} end
  add{Name="odg_selected_label",     ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_detail_title",       ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_detail_vote_title",  ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  for i=1,3 do add{Name=string.format("odg_detail_vote_mode_%d",i),ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1} end
  add{Name="odg_detail_preset",      ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  for i=1,5 do add{Name=string.format("odg_detail_choice_label_%d",i),ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,5 do add{Name=string.format("odg_detail_choice_color_%d",i),ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,2 do add{Name=string.format("odg_detail_result_vis_%d",i),ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1} end
  add{Name="odg_detail_realtime",    ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_json_export",        ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_json_import",        ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_do_export",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_do_import",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_file_list",          ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_scan_folder",        ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="odg_load_file",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}

  -- Tab 2: Riunione
  add{Name="mtg_status_led",         ControlType="Indicator",IndicatorType="Led",PinStyle="Output",UserPin=true,Count=1}
  add{Name="mtg_status_text",        ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="mtg_start",              ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="mtg_end",                ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="mtg_current_item_text",  ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="mtg_current_item_num",   ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="mtg_prev_item",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="mtg_next_item",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="mtg_start_discussion",   ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="mtg_stop_discussion",    ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="mtg_discussion_status",  ControlType="Text",PinStyle="Both",UserPin=true,Count=1}

  -- Tab 3: Votazione
  add{Name="vote_status_led",        ControlType="Indicator",IndicatorType="Led",PinStyle="Output",UserPin=true,Count=1}
  add{Name="vote_status_text",       ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="vote_use_config",        ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}
  add{Name="vote_title_display",     ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="vote_manual_title",      ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  for i=1,5 do add{Name=string.format("vote_choice_label_%d",i),ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,5 do add{Name=string.format("vote_choice_color_%d",i),ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  add{Name="vote_num_choices",       ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  for i=1,2 do add{Name=string.format("vote_result_vis_%d",i),ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1} end
  add{Name="vote_realtime",          ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}
  add{Name="vote_start",             ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="vote_stop",              ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="vote_hide_results",      ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  for i=1,5 do add{Name=string.format("vote_result_label_%d",i),ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,5 do add{Name=string.format("vote_result_count_%d",i),ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,5 do add{Name=string.format("vote_result_bar_%d",i),  ControlType="Knob",ControlUnit="Float",Min=0,Max=100,PinStyle="Both",UserPin=true,Count=1} end
  for i=1,5 do add{Name=string.format("vote_result_pct_%d",i),  ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  add{Name="vote_total_votes",       ControlType="Text",PinStyle="Both",UserPin=true,Count=1}

  -- Tab 4: Risultati
  for i=1,20 do add{Name=string.format("res_item_title_%d",i),  ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,20 do add{Name=string.format("res_item_vtitle_%d",i), ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,20 do add{Name=string.format("res_item_summary_%d",i),ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,20 do add{Name=string.format("res_item_total_%d",i),  ControlType="Text",PinStyle="Both",UserPin=true,Count=1} end
  add{Name="res_clear",              ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="res_page_prev",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="res_page_next",          ControlType="Button",ButtonType="Trigger",PinStyle="Both",UserPin=true,Count=1}
  add{Name="res_page_indicator",     ControlType="Text",PinStyle="Both",UserPin=true,Count=1}

  -- Tab 5: Sistema
  add{Name="Defaultchannelselectorvolume",     ControlType="Knob",ControlUnit="Integer",Min=0,Max=32,PinStyle="Both",UserPin=true,Count=1}
  add{Name="DefaultchannelselectorvolumeText", ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="LoudSpeakervolume",                ControlType="Knob",ControlUnit="Integer",Min=0,Max=25,PinStyle="Both",UserPin=true,Count=1}
  add{Name="LoudSpeakervolumeText",            ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="SeatsList",    ControlType="Text",HTextAlign="Left",PinStyle="Both",UserPin=true,Count=1}
  add{Name="SpeakerList",  ControlType="Text",HTextAlign="Left",PinStyle="Both",UserPin=true,Count=1}
  add{Name="RequestList",  ControlType="Text",HTextAlign="Left",PinStyle="Both",UserPin=true,Count=1}
  add{Name="MeetingType",  ControlType="Indicator",IndicatorType="Led",PinStyle="Both",UserPin=true,Count=1}
  add{Name="MeetingTitle", ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="TurnOnMic",    ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}
  add{Name="TurnOffMic",   ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}
  add{Name="ToSpeaker",    ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}
  add{Name="Recording",       ControlType="Indicator",IndicatorType="Led",PinStyle="Both",UserPin=true,Count=1}
  add{Name="RecordingStatus", ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="StartRecording",  ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}
  local seats = props["Seats"].Value
  for i=1,seats do add{Name=string.format("SeatButton_%d",i),ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1} end
  for i=1,seats do add{Name=string.format("RequestLED_%d",i),ControlType="Indicator",IndicatorType="Led",PinStyle="Both",UserPin=true,Count=1} end

  -- Tab 6: Wireless
  add{Name="WirelessShutdown",   ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}
  add{Name="WirelessDeviceList", ControlType="Text",HTextAlign="Left",PinStyle="Both",UserPin=true,Count=1}
  add{Name="GetWirelessUnits",   ControlType="Button",ButtonType="Toggle",PinStyle="Both",UserPin=true,Count=1}

  -- Tab 7: Info
  add{Name="info_display",    ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  add{Name="license_core_id", ControlType="Text",PinStyle="Output",UserPin=true,Count=1}
  add{Name="license_status",  ControlType="Text",PinStyle="Output",UserPin=true,Count=1}

  return ctrls
end

function GetControlLayout(props)
  local layout   = {}
  local graphics = {}
  local pg = props["page_index"].Value
  local W  = 1100

  local function hdr(txt)
    table.insert(graphics,{Type="GroupBox",Fill=C.Hdr,StrokeWidth=0,CornerRadius=0,Position={0,0},Size={W,38}})
    table.insert(graphics,{Type="Label",Text=txt,Font="Lato",FontStyle="Bold",FontSize=14,Color=C.TV,HTextAlign="Left",Position={10,8},Size={W-20,22}})
  end
  local function lbl(txt,x,y,w,h,sz,col,align)
    table.insert(graphics,{Type="Label",Text=txt,FontSize=sz or 10,Color=col or C.LtGy,HTextAlign=align or "Left",Position={x,y},Size={w,h}})
  end
  local function sep(y)
    table.insert(graphics,{Type="GroupBox",Fill=C.Gray,StrokeWidth=0,Position={0,y},Size={W,1}})
  end
  local function gbox(txt,x,y,w,h)
    table.insert(graphics,{Type="GroupBox",Text=txt,TextFont="Lato",TextFontSize=9,TextColor=C.LtGy,Fill=C.Dark,StrokeColor=C.Gray,StrokeWidth=1,CornerRadius=4,Position={x,y},Size={w,h}})
  end
  local function connbar()
    table.insert(graphics,{Type="GroupBox",Fill={35,42,52},StrokeWidth=0,CornerRadius=0,Position={0,38},Size={W,30}})
    layout["conn_status_led"] ={Style="Led",Position={6,47},Size={14,14},Color=C.Grn,OffColor=C.Red,UnlinkOffColor=true}
    layout["conn_status_text"]={Style="Text",Position={24,45},Size={148,22},IsReadOnly=true,FontSize=9}
    layout["ConnectServer"]   ={Style="Button",Position={180,45},Size={88,22},Legend="Connetti",ButtonStyle="Toggle",Color=C.Grn,OffColor=C.Gray,UnlinkOffColor=true}
    layout["ConnectStatus"]   ={Style="ComboBox",Position={276,45},Size={90,22}}
    layout["Status"]          ={Style="Status",Position={374,44},Size={22,22}}
    layout["debug_log"]       ={Style="Text",Position={0,680},Size={W,50},IsReadOnly=true,FontSize=10}
  end

  -- ── Page 1: Ordine del Giorno ─────────────────────────────────────────────────
  if pg == 1 then
    hdr("Ordine del Giorno / Agenda")
    connbar()

    lbl("Titolo Riunione",10,76,120,14,9)
    layout["odg_meeting_title"]={Style="Text",Position={10,90},Size={420,22}}
    lbl("Data (GG/MM/AAAA)",438,76,130,14,9)
    layout["odg_meeting_date"]={Style="Text",Position={438,90},Size={130,22}}
    layout["odg_save_agenda"] ={Style="Button",Position={576,89},Size={92,24},Legend="Salva",Color=C.Blu}
    layout["odg_load_agenda"] ={Style="Button",Position={674,89},Size={92,24},Legend="Carica"}
    layout["odg_new_agenda"]  ={Style="Button",Position={772,89},Size={110,24},Legend="Nuovo OdG",Color=C.Orn}

    lbl("Date salvate:",10,119,90,14,9)
    for i=1,4 do
      local x=100+(i-1)*248
      layout[string.format("odg_date_label_%d",i)]  ={Style="Text",Position={x,117},Size={170,18},IsReadOnly=true}
      layout[string.format("odg_date_select_%d",i)] ={Style="Button",Position={x+172,115},Size={72,22},Legend="Carica"}
    end

    sep(139)
    lbl("N°",10,144,30,14,9,C.TV)
    lbl("Titolo Punto / Item Title",44,144,620,14,9,C.TV)
    lbl("Voto?",670,144,60,14,9,C.TV)
    lbl("Sel.",740,144,60,14,9,C.TV)

    for i=1,5 do
      local y=160+(i-1)*36
      layout[string.format("odg_item_title_%d",i)]    ={Style="Text",Position={44,y},Size={620,22},IsReadOnly=true}
      layout[string.format("odg_item_has_vote_%d",i)] ={Style="Button",Position={670,y},Size={60,22},Legend="V",ButtonStyle="Toggle",Color=C.Grn,OffColor=C.Gray,UnlinkOffColor=true}
      layout[string.format("odg_item_select_%d",i)]   ={Style="Button",Position={740,y},Size={60,22},Legend="Sel.",ButtonStyle="Toggle",Color=C.Blu,OffColor=C.Gray,UnlinkOffColor=true}
    end

    layout["odg_page_prev"]     ={Style="Button",Position={10,348},Size={80,24},Legend="◀ Prec."}
    layout["odg_page_indicator"]={Style="Text",Position={96,348},Size={160,24},IsReadOnly=true}
    layout["odg_page_next"]     ={Style="Button",Position={262,348},Size={80,24},Legend="Succ. ▶"}
    layout["odg_add_item"]      ={Style="Button",Position={370,348},Size={110,24},Legend="+ Aggiungi",Color=C.Grn}
    layout["odg_remove_item"]   ={Style="Button",Position={486,348},Size={110,24},Legend="- Rimuovi",Color=C.Red}
    layout["odg_move_up"]       ={Style="Button",Position={602,348},Size={60,24},Legend="Su"}
    layout["odg_move_down"]     ={Style="Button",Position={668,348},Size={60,24},Legend="Giu"}

    sep(380)
    layout["odg_selected_label"]   ={Style="Text",Position={10,386},Size={1078,18},IsReadOnly=true}
    lbl("Titolo punto:",10,410,90,14,9)
    layout["odg_detail_title"]     ={Style="Text",Position={10,424},Size={1078,22}}
    lbl("Titolo votazione:",10,452,100,14,9)
    layout["odg_detail_vote_title"]={Style="Text",Position={10,466},Size={1078,22}}

    lbl("Scelte:",10,494,50,14,9)
    for i=1,3 do
      layout[string.format("odg_detail_vote_mode_%d",i)]={Style="Button",Position={62+(i-1)*62,492},Size={58,22},Legend=tostring(i+2).." sc.",ButtonStyle="Toggle",Color=C.Blu,OffColor=C.Gray,UnlinkOffColor=true}
    end
    layout["odg_detail_preset"]={Style="Button",Position={254,492},Size={90,22},Legend="Preset",Color=C.TV}

    lbl("Scelte 1-5 / label + colore hex",10,508,300,12,8)
    for i=1,5 do
      local row=math.ceil(i/2); local col=((i-1)%2)
      local bx=10+col*548; local by=520+(row-1)*24
      layout[string.format("odg_detail_choice_label_%d",i)]={Style="Text",Position={bx,by},Size={270,20}}
      layout[string.format("odg_detail_choice_color_%d",i)]={Style="Text",Position={bx+274,by},Size={100,20}}
    end

    layout[string.format("odg_detail_result_vis_%d",1)]={Style="Button",Position={940,520},Size={75,20},Legend="Pubbl.",ButtonStyle="Toggle",Color=C.Grn,OffColor=C.Gray,UnlinkOffColor=true}
    layout[string.format("odg_detail_result_vis_%d",2)]={Style="Button",Position={940,544},Size={75,20},Legend="Indiv.",ButtonStyle="Toggle",Color=C.Orn,OffColor=C.Gray,UnlinkOffColor=true}
    layout["odg_detail_realtime"]={Style="Button",Position={1020,520},Size={68,44},Legend="Realtime",ButtonStyle="Toggle",Color=C.Blu,OffColor=C.Gray,UnlinkOffColor=true}

    sep(576)
    lbl("Export JSON:",10,582,80,12,9)
    layout["odg_json_export"]={Style="Text",Position={10,596},Size={530,60}}
    layout["odg_do_export"]  ={Style="Button",Position={10,660},Size={120,18},Legend="Genera Export"}
    lbl("Import JSON:",556,582,80,12,9)
    layout["odg_json_import"]={Style="Text",Position={556,596},Size={532,60}}
    layout["odg_do_import"]  ={Style="Button",Position={556,660},Size={120,18},Legend="Importa",Color=C.Blu}

    sep(682)
    lbl("Agenda disponibili:",10,688,160,12,9)
    layout["odg_file_list"]   ={Style="ComboBox",Position={10,702},Size={W-130,22}}
    layout["odg_scan_folder"] ={Style="Button",Position={W-116,702},Size={106,22},Legend="Cerca file JSON"}
    layout["odg_load_file"]   ={Style="Button",Position={10,728},Size={180,22},Legend="Carica selezionato",Color=C.Blu}
    layout["debug_log"]       ={Style="Text",Position={0,756},Size={W,50},IsReadOnly=true,FontSize=10}

  -- ── Page 2: Riunione ─────────────────────────────────────────────────────────
  elseif pg == 2 then
    hdr("Riunione / Meeting")
    connbar()

    layout["mtg_status_led"] ={Style="Led",Position={10,82},Size={16,16},Color=C.Grn,OffColor=C.Gray,UnlinkOffColor=true}
    layout["mtg_status_text"]={Style="Text",Position={30,80},Size={300,20},IsReadOnly=true}
    layout["mtg_start"]      ={Style="Button",Position={10,108},Size={210,36},Legend="▶ Avvia Riunione",Color=C.Grn}
    layout["mtg_end"]        ={Style="Button",Position={230,108},Size={210,36},Legend="■ Termina Riunione",Color=C.Red}

    sep(154)
    lbl("Punto corrente / Current Item",10,162,300,14,10,C.TV)
    layout["mtg_current_item_text"]={Style="Text",Position={10,180},Size={1078,80},IsReadOnly=true,FontSize=20}
    layout["mtg_current_item_num"] ={Style="Text",Position={10,268},Size={1078,24},IsReadOnly=true,FontSize=13}
    layout["mtg_prev_item"]={Style="Button",Position={10,300},Size={180,36},Legend="◀ Precedente"}
    layout["mtg_next_item"]={Style="Button",Position={200,300},Size={180,36},Legend="Successivo ▶"}

    sep(346)
    lbl("Discussione / Discussion",10,354,250,14,10,C.TV)
    layout["mtg_start_discussion"] ={Style="Button",Position={10,372},Size={220,36},Legend="▶ Avvia Discussione",Color=C.Grn}
    layout["mtg_stop_discussion"]  ={Style="Button",Position={240,372},Size={220,36},Legend="■ Ferma Discussione",Color=C.Orn}
    layout["mtg_discussion_status"]={Style="Text",Position={10,418},Size={1078,22},IsReadOnly=true}

  -- ── Page 3: Votazione ────────────────────────────────────────────────────────
  elseif pg == 3 then
    hdr("Votazione / Voting")
    connbar()

    layout["vote_status_led"] ={Style="Led",Position={10,82},Size={16,16},Color=C.Grn,OffColor=C.Gray,UnlinkOffColor=true}
    layout["vote_status_text"]={Style="Text",Position={30,80},Size={300,20},IsReadOnly=true}
