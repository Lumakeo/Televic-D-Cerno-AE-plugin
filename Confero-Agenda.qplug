  add{Name="vote_result_label",      ControlType="Text",PinStyle="Both",UserPin=true,Count=6}
  add{Name="vote_result_count",      ControlType="Text",PinStyle="Both",UserPin=true,Count=6}
  add{Name="vote_result_bar",        ControlType="Knob",ControlUnit="Float",Min=0,Max=100,PinStyle="Both",UserPin=true,Count=6}
  add{Name="vote_result_pct",        ControlType="Text",PinStyle="Both",UserPin=true,Count=6}
  add{Name="vote_total_votes",       ControlType="Text",PinStyle="Both",UserPin=true,Count=1}
  -- Tab 4
  add{Name="res_item_title",         ControlType="Text",PinStyle="Both",UserPin=true,Count=20}
  add{Name="res_item_vtitle",        ControlType="Text",PinStyle="Both",UserPin=true,Count=20}
